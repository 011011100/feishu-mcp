{
  "type": "node",
  "name": "feishu-mcp",
  "version": "1.0.0",
  "description": "Feishu Bitable MCP Server on Zeabur",
  "scripts": {
    "build": "echo 'No build step'",
    "start": "node --import tsx server/mcp/http.ts"
  },
  "env": {
    "FEISHU_APP_ID": {
      "required": true
    },
    "FEISHU_APP_SECRET": {
      "required": true
    },
    "PORT": {
      "default": "3000"
    }
  }
}
